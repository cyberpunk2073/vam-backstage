<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- Builds are ad-hoc signed (no Apple Developer cert). With hardened runtime
         active, macOS enforces library validation, which rejects Electron's
         pre-signed framework because ad-hoc binaries carry no Team ID (crash:
         "not valid for use in process: ... different Team IDs"). Disabling
         library validation is the electron-builder-recommended fix that keeps
         hardened runtime on. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
  </dict>
</plist>
